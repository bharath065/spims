# Chatbot microservice environment variables
# Copy this file to .env and adjust the values for your environment.

# --- Service URLs ---
# In Docker Compose these point to the service names.
BACKEND_URL=http://backend:8000
ML_URL=http://ml_module:8001

# --- Chatbot server ---
CHATBOT_PORT=8002
LOG_LEVEL=INFO

# --- HTTP client timeout (seconds) ---
TIMEOUT=10.0
